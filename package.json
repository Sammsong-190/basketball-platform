{
  "name": "basketball-platform",
  "version": "1.0.0",
  "description": "篮球用品电商社交平台 - Monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=basketball-platform-web",
    "dev:web": "npm run dev --workspace=basketball-platform-web",
    "dev:admin": "npm run dev --workspace=basketball-platform-admin",
    "dev:backend": "npm run dev --workspace=basketball-platform-backend",
    "build": "npm run build --workspace=basketball-platform-web",
    "build:web": "npm run build --workspace=basketball-platform-web",
    "build:admin": "npm run build --workspace=basketball-platform-admin",
    "start": "npm run start --workspace=basketball-platform-web",
    "db:generate": "npm run db:generate --workspace=basketball-platform-web",
    "db:push": "npm run db:push --workspace=basketball-platform-web",
    "db:migrate": "npm run db:migrate --workspace=basketball-platform-web",
    "db:studio": "npm run db:studio --workspace=basketball-platform-web",
    "db:migrate-to-tidb": "node scripts/migrate-to-tidb.js",
    "create-admin": "npm run create-admin --workspace=basketball-platform-web",
    "upgrade-admin": "npm run upgrade-admin --workspace=basketball-platform-web",
    "init-categories": "npm run init-categories --workspace=basketball-platform-web"
  },
  "keywords": [
    "basketball",
    "ecommerce",
    "social",
    "platform",
    "monorepo"
  ],
  "author": "",
  "license": "MIT"
}
